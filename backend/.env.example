# Server Configuration
PORT=5000
NODE_ENV=development

# Option 1: Supabase connection string (recommended for production)
# Use port 6543 for the connection pooler, 5432 for direct connection
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require

# Option 2: Individual DB vars (used by migration scripts, fallback if no DATABASE_URL)
DB_HOST=db.<project-ref>.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=<your-supabase-db-password>

# CORS — set to your deployed frontend URL in production
FRONTEND_URL=http://localhost:3000

# JWT — use a long random string in production (never commit the real value)
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=24h
